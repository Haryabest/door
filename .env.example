# Пустая строка = тот же origin (в dev Vite проксирует /api на бекенд).
# Если фронт и API на разных доменах — укажите базовый URL API, например: https://api.example.com
VITE_API_URL=

# Тот же токен, что ADMIN_API_TOKEN на сервере — для админки (мутации). В проде не кладите в публичный билд без защиты домена.
VITE_ADMIN_API_TOKEN=
