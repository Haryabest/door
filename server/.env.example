# PostgreSQL (# в пароле в URL кодируйте как %23)
DATABASE_URL=postgresql://door_user:door%23132@localhost:5432/door_db

# Секрет для мутаций через Bearer (скрипты, CI). Браузер после входа использует cookie-сессию.
# В production рекомендуется задать. Если пусто — в dev мутации без авторизации (см. authMutations).
ADMIN_API_TOKEN=

# Пароль админки хранится в таблице admin_credential (миграция 003, по умолчанию admin123).
# Смена: npm run set-admin-password -- 'новый_пароль'

# Подпись cookie сессии (опционально). По умолчанию используется ADMIN_API_TOKEN.
# ADMIN_SESSION_SECRET=

# Cookie с флагом Secure (только для HTTPS). На http:// задайте пусто или не ставьте переменную.
# ADMIN_COOKIE_SECURE=true

# API port (reverse proxy targets this)
PORT=3001

# Allowed browser origin(s), comma-separated
CORS_ORIGIN=http://localhost:5173

# За nginx / CDN: число прокси-хопов для корректного IP (rate limit)
TRUST_PROXY_HOPS=1

# Пул соединений к PostgreSQL
# PG_POOL_MAX=20
# PG_IDLE_MS=30000
# PG_CONNECT_TIMEOUT_MS=10000

# Лимит запросов к /api (за 15 минут на IP по умолчанию)
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=400

# Логи HTTP: combined | dev | short
# LOG_FORMAT=combined

# Публичный базовый URL для ссылок на загрузки (если фронт на другом домене)
PUBLIC_BASE_URL=
